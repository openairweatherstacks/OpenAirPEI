# Copy to .env.local for development.

# AI (Claude via AI Gateway or direct — see project docs)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Weather station (Tempest)
TEMPEST_API_TOKEN=
TEMPEST_STATION_ID=

# Neon Postgres — provision via Vercel Dashboard: Storage → Neon, or run locally:
#   vercel link
#   vercel integration add neon
#   vercel env pull .env.local --yes
DATABASE_URL=

# Vercel Blob — Storage → Blob, or: vercel integration add vercel-blob then vercel env pull
BLOB_READ_WRITE_TOKEN=

# Admin bearer for POST /api/reviews/approve and similar
OPENAIR_ADMIN_KEY=

# Bearer for /api/cron/* routes
CRON_SECRET=

# Provisioning note: Marketplace integrations (Neon, Blob) cannot be run from CI sandboxes.
# On your machine, link the Vercel project and run the integration / env pull commands above,
# or add DATABASE_URL and BLOB_READ_WRITE_TOKEN in the Vercel project settings.
